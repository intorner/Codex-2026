rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 第一個集合：任何人可讀寫
    match /wordcloud_words/{document} {
      allow read, write: if true;
    }

    // 連線測試集合：任何人可讀寫
    match /test_collection/{document} {
      allow read, write: if true;
    }

    // 其他集合預設禁止存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
